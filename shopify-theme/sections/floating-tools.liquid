{{ 'sections-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_heading = section.settings.heading | strip
-%}

<section class="pt-floating-tools section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="pt-floating-tools__panel" role="region" aria-label="{{ section_heading | default: 'Floating tools' | escape }}">
    {%- if section_heading != blank -%}
      <p class="visually-hidden">{{ section_heading | escape }}</p>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- liquid
        assign icon_markup = block.settings.icon_svg | strip
        assign remote_icon_url = block.settings.remote_icon_url | strip
        assign block_label = block.settings.label | strip
      -%}
      <a
        class="pt-floating-tools__item"
        {% if block.settings.link != blank %}
          href="{{ block.settings.link }}"
        {% else %}
          role="link" aria-disabled="true"
        {% endif %}
        aria-label="{{ block_label | default: 'Tool link' | escape }}"
        {{ block.shopify_attributes }}
      >
        <span class="pt-floating-tools__icon" aria-hidden="true">
          {%- if icon_markup != blank -%}
            {{ icon_markup }}
          {%- elsif remote_icon_url != blank -%}
            <img src="{{ remote_icon_url }}" alt="" loading="lazy" width="28" height="28">
          {%- else -%}
            <span class="pt-floating-tools__dot"></span>
          {%- endif -%}
        </span>
        {%- if block_label != blank -%}
          <span class="pt-floating-tools__label">{{ block_label | escape }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "PT Floating tools",
  "tag": "section",
  "class": "section section-pt-floating-tools",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Accessibility heading",
      "default": "Floating contact tools"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "tool",
      "name": "Tool",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "WhatsApp"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "url",
          "id": "remote_icon_url",
          "label": "Remote icon URL"
        },
        {
          "type": "liquid",
          "id": "icon_svg",
          "label": "Inline SVG icon"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "PT Floating tools",
      "blocks": [
        {
