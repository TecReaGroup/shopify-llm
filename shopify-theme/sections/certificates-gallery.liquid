{{ 'sections-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_heading = section.settings.heading | strip
  assign section_subheading = section.settings.subheading | strip
  assign section_description = section.settings.description | strip
-%}

<section class="pt-certificates-gallery section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="pt-certificates-gallery__header{% if section_heading == blank and section_subheading == blank and section_description == blank %} pt-certificates-gallery__header--empty{% endif %}">
      {%- if section_subheading != blank -%}
        <p class="pt-certificates-gallery__eyebrow">{{ section_subheading | escape }}</p>
      {%- endif -%}
      {%- if section_heading != blank -%}
        <h2 class="pt-certificates-gallery__heading h1">{{ section_heading | escape }}</h2>
      {%- endif -%}
      {%- if section_description != blank -%}
        <div class="pt-certificates-gallery__description rte">
          <p>{{ section_description | escape }}</p>
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="pt-certificates-gallery__rows">
        {%- for row in (1..2) -%}
          {%- liquid
            assign row_index = row | append: ''
            assign row_size = 0
            for block in section.blocks
              if block.settings.gallery_row == row_index
                assign row_size = row_size | plus: 1
              endif
            endfor
          -%}
          {%- if row_size > 0 -%}
            <div class="pt-certificates-gallery__row pt-certificates-gallery__row--{{ row }}" role="list">
              {%- for block in section.blocks -%}
                {%- if block.settings.gallery_row == row_index -%}
                  {%- liquid
                    assign remote_image_url = block.settings.remote_image_url | strip
                    assign image_url = ''
                    if block.settings.image != blank
                      assign image_url = block.settings.image | image_url: width: 1200
                    elsif remote_image_url != blank
                      assign image_url = remote_image_url
                    endif
                  -%}
                  <article class="pt-certificates-gallery__card" {{ block.shopify_attributes }} role="listitem">
                    <div class="pt-certificates-gallery__media{% if image_url == blank %} pt-certificates-gallery__media--placeholder{% endif %}">
                      {%- if image_url != blank -%}
                        <img
                          src="{{ image_url }}"
                          alt="{{ block.settings.alt_text | default: block.settings.title | default: section_heading | escape }}"
                          loading="lazy"
                          width="600"
                          height="420"
                        >
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                    {%- if block.settings.title != blank or block.settings.caption != blank -%}
                      <div class="pt-certificates-gallery__caption">
                        {%- if block.settings.title != blank -%}
                          <h3>{{ block.settings.title | escape }}</h3>
                        {%- endif -%}
                        {%- if block.settings.caption != blank -%}
                          <p>{{ block.settings.caption | escape }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </article>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PT Certificates gallery",
  "tag": "section",
  "class": "section section-pt-certificates-gallery",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow",
      "default": "CERTIFICATE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Professional certificates and factory credentials"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Showcase the full-width certificate wall with two justified rows to mirror the original homepage credibility section."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "certificate",
      "name": "Certificate",
      "settings": [
        {
          "type": "select",
          "id": "gallery_row",
          "label": "Gallery row",
          "default": "1",
          "options": [
            {
              "value": "1",
              "label": "Row 1"
            },
            {
              "value": "2",
              "label": "Row 2"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "remote_image_url",
          "label": "Remote image URL"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Factory certificate"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "PT Certificates gallery",
      "blocks": [
        {
